# Unsiloed AI — https://docs.unsiloed.ai
UNSILOED_API_KEY=

# --- LLM provider (NL→SQL, synthesis, sentiment, anomaly hints) ---
# Default is OpenAI. Set LLM_PROVIDER to switch: openai | anthropic | nebius
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Nebius Token Factory (OpenAI-compatible). Only used when LLM_PROVIDER=nebius.
NEBIUS_API_KEY=
# NEBIUS_SYNTHESIS_MODEL=nvidia/Nemotron-3-Ultra-550b-a55b

# Resend — board report email (stretch)
RESEND_API_KEY=

# Postgres (docker-compose default). Read-only role for NL->SQL.
DATABASE_URL=postgresql+psycopg://findoc:findoc@localhost:5434/financial_document_os
DATABASE_READONLY_URL=postgresql+psycopg://findoc_ro:findoc_ro@localhost:5434/financial_document_os

# Backend / frontend URLs
APP_URL=http://localhost:3006
NEXT_PUBLIC_API_URL=http://localhost:8001
