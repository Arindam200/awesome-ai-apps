# Couchbase Configuration
COUCHBASE_CONNECTION_STRING=
COUCHBASE_USERNAME=
COUCHBASE_PASSWORD=
COUCHBASE_BUCKET=transactions
COUCHBASE_SCOPE=_default

# Collection Names
TRANSACTIONS_COLLECTION=transactions
DECISIONS_COLLECTION=decisions
HUMAN_REVIEWS_COLLECTION=human_reviews

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Temporal Configuration
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=transaction-processing

# API Configuration
API_BASE_URL=http://localhost:8000/api

# API authentication
# Set API_KEY to enable X-API-Key auth on the transaction/metrics endpoints
# (POST/GET /api/transaction*, /api/metrics). Leave it blank to run in dev mode,
# where those endpoints are unprotected. The bundled client (app.py and
# scripts/advanced_scenarios.py) reads this SAME variable and sends it as the
# X-API-Key header, so set it here once and both the server and client agree.
API_KEY=

# Business Rules
AUTO_APPROVAL_LIMIT=50000
CONFIDENCE_THRESHOLD_APPROVE=85
SIMILARITY_THRESHOLD=0.85
