# Unsiloed AI — https://docs.unsiloed.ai
UNSILOED_API_KEY=

# --- LLM provider (synthesis + sentiment) ---
# Default is OpenAI. Set LLM_PROVIDER to switch: openai | anthropic | nebius
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Nebius Token Factory (OpenAI-compatible). Only used when LLM_PROVIDER=nebius.
NEBIUS_API_KEY=
# NEBIUS_SYNTHESIS_MODEL=nvidia/Nemotron-3-Ultra-550b-a55b

# GitHub personal access token (public_repo scope is enough)
GITHUB_TOKEN=

# Resend — newsletter delivery
RESEND_API_KEY=

# Postgres (docker-compose default)
DATABASE_URL=postgresql+psycopg://brief:brief@localhost:5433/maintainer_brief

# Where the dashboard lives (used for "View source" deep links in the email)
APP_URL=http://localhost:3005

# Backend API URL (used by the Next.js frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000
