# Mandatory: your Nebius Token Factory API key
NEBIUS_API_KEY=your_api_key_here

# Optional overrides
# NVIDIA reasoning model served by Nebius Token Factory
COSMOS_MODEL=nvidia/Cosmos3-Super-Reasoner
# OpenAI-compatible Nebius Token Factory base URL
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
