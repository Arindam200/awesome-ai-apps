# Nebius Token Factory API key — used for all LLM calls via app.ai()
# AgentField uses LiteLLM internally, so just set this and you're good.
NEBIUS_API_KEY=your-nebius-api-key

# AgentField Control Plane URL — the agent registers here for dashboard visibility.
# Start the control plane with: af server
# Dashboard available at: http://localhost:8080/ui
AGENTFIELD_SERVER=http://localhost:8080

# No other API keys needed:
# - yfinance (financial data) is completely free
# - AgentField Agent() requires no api_key parameter
