# Copy to `.env` (gitignored) before running the stack.
# These are DEMO values. In production, secrets come from a secret manager and
# the Postgres source uses IAM (no password at all) — see deploy/k8s/.

# --- Postgres (owner + the three least-privilege roles) ----------------------
# The role passwords MUST match the literals in db/postgres/01_roles.sql.
PG_DATABASE=grocery
POSTGRES_PASSWORD=postgres_owner_pw

PG_HOST=postgres
PG_PORT=5432
PG_APP_USER=toolbox_app
PG_APP_PASSWORD=app_demo_pw_change_me
PG_ADMIN_USER=toolbox_admin
PG_ADMIN_PASSWORD=admin_demo_pw_change_me

# --- MongoDB (Atlas Local, single-node replica set) --------------------------
MONGO_URI=mongodb://mongo:27017/?directConnection=true

# --- Keycloak / OIDC ---------------------------------------------------------
OIDC_ISSUER=http://keycloak:8080/realms/grocery
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=grocery
KEYCLOAK_CLIENT_ID=grocery-agent
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin

# --- Toolbox + app -----------------------------------------------------------
TOOLBOX_URL=http://toolbox:5000
STORE_REGION=us-west
CATALOG_SIZE=150

# --- Agent LLM: Nebius Token Factory (Kimi-K2.6) by default -------------------
# Used ONLY for the conversational chat; the security demo endpoints work without it.
AGENT_PROVIDER=nebius
AGENT_MODEL=moonshotai/Kimi-K2.6
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.us-central1.nebius.com/v1/

# --- Gemini: embeddings ONLY (semantic product search). Nebius has no embedding
#     models and the inventory vectors are Gemini, so query embedding stays here.
#     Leave blank to skip semantic search; cart/checkout/security demo still work.
#     (Set AGENT_PROVIDER=gemini + AGENT_MODEL=gemini-2.5-flash to use Gemini for chat too.)
GOOGLE_API_KEY=
