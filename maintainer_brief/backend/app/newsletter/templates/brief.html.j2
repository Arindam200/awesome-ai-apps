<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ project_name }} Maintainer Brief</title>
</head>
<body style="margin:0; padding:0; background-color:#f5f4f0; font-family:Georgia, 'Times New Roman', serif;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f5f4f0; padding:24px 0;">
<tr><td align="center">
<table role="presentation" width="600" cellpadding="0" cellspacing="0" style="width:600px; max-width:600px; background-color:#ffffff; border:1px solid #e3e0d8;">

  <!-- Header -->
  <tr><td style="padding:36px 40px 24px 40px; border-bottom:3px solid #1a1a1a;">
    <div style="font-family:Helvetica, Arial, sans-serif; font-size:11px; letter-spacing:2px; text-transform:uppercase; color:#b3502d; font-weight:bold;">Maintainer Intelligence Brief</div>
    <div style="font-size:30px; color:#1a1a1a; margin-top:8px; line-height:1.2;">{{ project_name }}</div>
    <div style="font-family:Helvetica, Arial, sans-serif; font-size:12px; color:#888; margin-top:8px;">{{ period_start }} &ndash; {{ period_end }} &middot; {{ signal_count }} signals analyzed</div>
  </td></tr>

  <!-- Headline -->
  <tr><td style="padding:28px 40px 8px 40px;">
    <div style="font-size:19px; font-style:italic; color:#333; line-height:1.45;">{{ brief.headline }}</div>
  </td></tr>

  {% macro section_header(title) -%}
  <tr><td style="padding:28px 40px 4px 40px;">
    <div style="font-family:Helvetica, Arial, sans-serif; font-size:12px; letter-spacing:1.5px; text-transform:uppercase; color:#b3502d; font-weight:bold; border-bottom:1px solid #e3e0d8; padding-bottom:6px;">{{ title }}</div>
  </td></tr>
  {%- endmacro %}

  {% macro source_links(ids) -%}
    {% for sid in ids[:3] %}<a href="{{ app_url }}/citations/{{ sid }}" style="font-family:Helvetica, Arial, sans-serif; font-size:11px; color:#b3502d; text-decoration:none;">View source&nbsp;&#8599;</a>{% if not loop.last %}&nbsp;&middot;&nbsp;{% endif %}{% endfor %}
  {%- endmacro %}

  {% if sections.top_requested_features and brief.top_requested_features %}
  {{ section_header("Top Requested Features") }}
  {% for f in brief.top_requested_features %}
  <tr><td style="padding:14px 40px 4px 40px;">
    <div style="font-size:16px; color:#1a1a1a; font-weight:bold;">{{ f.cluster_name }}
      <span style="font-family:Helvetica, Arial, sans-serif; font-size:10px; font-weight:bold; letter-spacing:1px; text-transform:uppercase; color:{% if f.urgency in ['high','critical'] %}#b3502d{% else %}#888{% endif %}; padding-left:8px;">{{ f.urgency }}</span>
    </div>
    <div style="font-size:14px; color:#444; line-height:1.5; margin-top:4px;">{{ f.summary }}</div>
    <div style="margin-top:6px;">{{ source_links(f.signal_ids) }}</div>
  </td></tr>
  {% endfor %}
  {% endif %}

  {% if sections.community_health and brief.community_health %}
  {{ section_header("Community Health") }}
  <tr><td style="padding:14px 40px 4px 40px;">
    <div style="font-size:14px; color:#444; line-height:1.5;">{{ brief.community_health.summary }}</div>
    {% for callout in brief.community_health.metrics_callouts %}
    <div style="font-family:Helvetica, Arial, sans-serif; font-size:13px; color:#1a1a1a; margin-top:6px;">&#9656;&nbsp;{{ callout }}</div>
    {% endfor %}
  </td></tr>
  {% endif %}

  {% if sections.ecosystem_mentions and brief.ecosystem_mentions %}
  {{ section_header("Ecosystem Mentions") }}
  {% for m in brief.ecosystem_mentions %}
  <tr><td style="padding:14px 40px 4px 40px;">
    <div style="font-size:14px; color:#444; line-height:1.5;">{{ m.context }}{% if m.prominence %} <span style="font-family:Helvetica, Arial, sans-serif; font-size:11px; color:#888;">({{ m.prominence }})</span>{% endif %}</div>
    <div style="margin-top:6px;">{{ source_links(m.signal_ids) }}</div>
  </td></tr>
  {% endfor %}
  {% endif %}

  {% if sections.competitor_watch and brief.competitor_watch %}
  {{ section_header("Competitor Watch") }}
  {% for c in brief.competitor_watch %}
  <tr><td style="padding:14px 40px 4px 40px;">
    <div style="font-size:16px; color:#1a1a1a; font-weight:bold;">{{ c.competitor }}</div>
    <div style="font-size:14px; color:#444; line-height:1.5; margin-top:4px;">{{ c.development }}</div>
    <div style="font-size:13px; color:#777; font-style:italic; line-height:1.5; margin-top:4px;">Why it matters: {{ c.why_it_matters }}</div>
    <div style="margin-top:6px;">{{ source_links(c.signal_ids) }}</div>
  </td></tr>
  {% endfor %}
  {% endif %}

  {% if sections.security_alerts and brief.security_alerts %}
  {{ section_header("Security Alerts") }}
  {% for s in brief.security_alerts %}
  <tr><td style="padding:14px 40px 4px 40px;">
    <div style="font-size:15px; color:#1a1a1a; font-weight:bold;">{{ s.identifier }}
      <span style="font-family:Helvetica, Arial, sans-serif; font-size:10px; font-weight:bold; letter-spacing:1px; text-transform:uppercase; color:#b3502d; padding-left:8px;">{{ s.severity }}</span>
    </div>
    <div style="font-size:14px; color:#444; line-height:1.5; margin-top:4px;">{{ s.action }}</div>
    <div style="margin-top:6px;">{{ source_links(s.signal_ids) }}</div>
  </td></tr>
  {% endfor %}
  {% endif %}

  {% if sections.maintainer_recommendations and brief.maintainer_recommendations %}
  {{ section_header("Recommended Actions") }}
  {% for r in brief.maintainer_recommendations %}
  <tr><td style="padding:14px 40px 4px 40px;">
    <div style="font-size:15px; color:#1a1a1a;"><span style="font-family:Helvetica, Arial, sans-serif; font-weight:bold; color:#b3502d;">{{ loop.index }}.</span>&nbsp;<strong>{{ r.recommendation }}</strong>
      <span style="font-family:Helvetica, Arial, sans-serif; font-size:10px; letter-spacing:1px; text-transform:uppercase; color:#888; padding-left:6px;">{{ r.effort }}</span>
    </div>
    <div style="font-size:13px; color:#777; line-height:1.5; margin-top:4px;">{{ r.rationale }}</div>
    <div style="margin-top:6px;">{{ source_links(r.supporting_signal_ids) }}</div>
  </td></tr>
  {% endfor %}
  {% endif %}

  <!-- Footer -->
  <tr><td style="padding:32px 40px 36px 40px; border-top:1px solid #e3e0d8; margin-top:24px;">
    <div style="font-family:Helvetica, Arial, sans-serif; font-size:12px; color:#888; line-height:1.6;">
      Signals extracted from GitHub, Hacker News, Reddit, security advisories, and document sources
      (conference decks, reports, RFCs) &mdash; documents parsed into structured JSON with
      <a href="https://unsiloed.ai" style="color:#b3502d; text-decoration:none;">Unsiloed</a>,
      with word-level citations. Click any &ldquo;View source&rdquo; link to see the exact highlighted
      region in the original document.<br><br>
      <a href="{{ app_url }}" style="color:#b3502d; text-decoration:none;">Open dashboard&nbsp;&#8599;</a>
    </div>
  </td></tr>

</table>
</td></tr>
</table>
</body>
</html>
